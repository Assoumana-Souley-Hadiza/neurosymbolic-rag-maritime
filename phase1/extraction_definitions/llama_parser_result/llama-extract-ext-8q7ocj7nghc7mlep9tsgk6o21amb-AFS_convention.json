{
  "data": {
    "document_title": "International Convention on the Control of Harmful Anti-Fouling Systems on Ships, 2001 (AFS Convention) – Glossary of Definitions",
    "glossary_terms": [
      {
        "term": "Administration",
        "language": "en",
        "definition": "means the Government of the State under whose authority the ship is operating. With respect to a ship entitled to fly a flag of a State, the Administration is the Government of that State. With respect to fixed or floating platforms engaged in exploration and exploitation of the sea-bed and subsoil thereof adjacent to the coast over which the coastal State exercises sovereign rights for the purposes of exploration and exploitation of their natural resources, the Administration is the Government of the coastal State concerned.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(1)"
      },
      {
        "term": "Anti-fouling system",
        "language": "en",
        "definition": "means a coating, paint, surface treatment, surface, or device that is used on a ship to control or prevent attachment of unwanted organisms.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(2)"
      },
      {
        "term": "Committee",
        "language": "en",
        "definition": "means the Marine Environment Protection Committee of the Organization.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(3)"
      },
      {
        "term": "Gross tonnage",
        "language": "en",
        "definition": "means the gross tonnage calculated in accordance with the tonnage measurement regulations contained in Annex 1 to the International Convention on Tonnage Measurement of Ships, 1969, or any successor Convention.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(4)"
      },
      {
        "term": "International voyage",
        "language": "en",
        "definition": "means a voyage by a ship entitled to fly the flag of one State to or from a port, shipyard, or offshore terminal under the jurisdiction of another State.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(5)"
      },
      {
        "term": "Length",
        "language": "en",
        "definition": "means the length as defined in the International Convention on Load Lines, 1966, as modified by the Protocol of 1988 relating thereto, or any successor Convention.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(6)"
      },
      {
        "term": "Organization",
        "language": "en",
        "definition": "means the International Maritime Organization.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(7)"
      },
      {
        "term": "Secretary-General",
        "language": "en",
        "definition": "means the Secretary-General of the Organization.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(8)"
      },
      {
        "term": "Ship",
        "language": "en",
        "definition": "means a vessel of any type whatsoever operating in the marine environment and includes hydrofoil boats, air-cushion vehicles, submersibles, floating craft, fixed or floating platforms, floating storage units (FSUs) and floating production storage and off-loading units (FPSOs).",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(9)"
      },
      {
        "term": "Technical Group",
        "language": "en",
        "definition": "is a body comprised of representatives of the Parties, Members of the Organization, the United Nations and its Specialized Agencies, intergovernmental organizations having agreements with the Organization, and non-governmental organizations in consultative status with the Organization, which should preferably include representatives of institutions and laboratories that engage in anti-fouling system analysis. These representatives shall have expertise in environmental fate and effects, toxicological effects, marine biology, human health, economic analysis, risk management, international shipping, anti-fouling systems coating technology, or other fields of expertise necessary to objectively review the technical merits of a comprehensive proposal.",
        "exclusions": null,
        "scientific_name": null,
        "article_reference": "Article 2(10)"
      }
    ]
  },
