# ═════════════════════════════════════════════════════════════════
# .env.local.example
# ═════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copier ce fichier en .env.local
# 2. Remplir les valeurs réelles
# 3. .env.local sera ignoré par git (voir .gitignore)
# 4. NE PAS commiter .env.local sur GitHub!
#
# cp .env.local.example .env.local
# ═════════════════════════════════════════════════════════════════

# ─── Neo4j Configuration ──────────────────────────────────────────
# URI de la base Neo4j
NEO4J_URI=bolt://localhost:7687

# Utilisateur Neo4j (défaut: neo4j)
NEO4J_USER=neo4j

# 🔴 CRITIQUE: Mot de passe Neo4j
# Changer "your_neo4j_password" par votre vrai mot de passe
NEO4J_PASSWORD=your_neo4j_password

# Base de données (défaut: neo4j)
NEO4J_DB=neo4j

# ─── Ollama / LLM Configuration ──────────────────────────────────
# URL de base d'Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Modèle LLM à utiliser (ex: mistral, llama2, neural-chat)
OLLAMA_MODEL=mistral

# Température du LLM (0.0 = déterministe, 1.0 = créatif)
LLM_TEMPERATURE=0.1

# ─── Versioning ──────────────────────────────────────────────────
# Version du modèle d'embedding (change si vous upgradez le modèle)
EMBEDDING_VERSION=bge-m3-v1

# Version de l'index BM25
BM25_VERSION=bm25-v1

# ─── Logging ─────────────────────────────────────────────────────
# Niveau de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Debug ───────────────────────────────────────────────────────
# Activer le mode debug (plus verbeux)
DEBUG=False

# ═════════════════════════════════════════════════════════════════
# ✅ Une fois configuré, tester avec:
# python -c "from rag.config import *; print('✅ Config OK')"
# ═════════════════════════════════════════════════════════════════
